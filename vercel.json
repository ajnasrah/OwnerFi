{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/run-agent-outreach-scraper",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/process-agent-outreach-queue",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/refresh-zillow-status",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v2/scraper/run",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/monthly-realtor-credits",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/drain-tcpa-pending",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sweep-abandoned-outreach",
      "schedule": "0 14 * * *"
    }
  ],
  "functions": {
    "src/app/api/admin/upload-properties-v4/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/refresh-zillow-status/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/run-agent-outreach-scraper/route.ts": {
      "maxDuration": 600
    },
    "src/app/api/cron/process-agent-outreach-queue/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/process-scraper-queue/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/v2/scraper/run/route.ts": {
      "maxDuration": 600
    },
    "src/app/api/v2/scraper/add/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/monthly-realtor-credits/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/drain-tcpa-pending/route.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/dashboard/setup",
      "has": [
        {
          "type": "query",
          "key": "type",
          "value": "buyer"
        }
      ],
      "destination": "/buyer/register",
      "permanent": false
    },
    {
      "source": "/dashboard/setup",
      "has": [
        {
          "type": "query",
          "key": "type", 
          "value": "realtor"
        }
      ],
      "destination": "/auth/setup?type=realtor",
      "permanent": false
    }
  ]
}